# ═══════════════════════════════════════════════════════════════════
#  Cafe Bloom POS — Environment Variables
#  Copy this file to .env (locally) or add to Railway Variables tab
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL (auto-set by Railway PostgreSQL plugin) ───────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_SECRET=your_random_64_char_hex_string_here

# ── Session expiry (hours) ────────────────────────────────────────
SESSION_EXPIRES_HOURS=720

# ── Telegram Bot (get from @BotFather on Telegram) ────────────────
# ⚠️  NEVER put these in App.jsx or any frontend code!
TG_BOT_TOKEN=1234567890:ABCdefGHI_jklMNOpqrSTUvwxYZ
TG_CHAT_ID=-1001234567890

# ── Server port (auto-set by Railway) ────────────────────────────
PORT=5000
